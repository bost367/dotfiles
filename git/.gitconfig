[pull]
	rebase = true
[core]
	autocrlf = input
	pager = delta
[delta]
    minus-style = "syntax" "#484A4A"
    minus-emph-style = "syntax" "#484A4A"
    minus-non-emph-style = "syntax" "#2F3032"
    plus-style = "syntax" "#294436"
    plus-emph-style = "syntax" "#294436"
    plus-non-emph-style = "syntax" "#212E2A"
    line-numbers = true
    side-by-side = false
    syntax-theme = Coldark-Dark 
    file-style = "white"
    hunk-header-style = omit
