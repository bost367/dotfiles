ignored_dirs=".git,node_modules,build,target,.idea,.gradle"
fdcwd() {
  echo "$@"
  # local cwd
  # cwd="$(git rev-parse --show-toplevel || pwd)"
  fd \
    --hidden \
    --follow \
    --type f \
    --exclude ".git" \
    .
    # --base-directory "$cwd"
}

export fdcwd

# walker-skip='

export FZF_DEFAULT_OPTS="
  --preview='bat --color=always {}'
  --info='right'
  --prompt=' '
  --marker=''
  --pointer='█'"

export FZF_DEFAULT_COMMAND="fd
  --hidden
  --follow
  --type f
  --exclude $ignored_dirs"


# source "darcula-theme.sh"
